# ==============================================
# ABUTECH AI SECURITY PLATFORM
# .gitignore
# ==============================================

# -----------------------------------------------
# SECRETS - NEVER COMMIT THESE
# -----------------------------------------------
.env
*.env
.env.local
.env.production
.env.staging
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------
# PYTHON
# -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/

# -----------------------------------------------
# JUPYTER NOTEBOOKS
# -----------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------
# MACHINE LEARNING
# -----------------------------------------------
# Trained model files - too large for GitHub
*.pkl
*.pickle
*.joblib
*.h5
*.pt
*.pth
*.onnx
models/trained/
mlruns/

# Large datasets - use DVC instead
data/raw/
data/processed/
*.csv
*.parquet
*.feather

# -----------------------------------------------
# DATABRICKS
# -----------------------------------------------
.databricks/
databricks.yml.local

# -----------------------------------------------
# VS CODE
# -----------------------------------------------
.vscode/settings.json
.vscode/launch.json

# -----------------------------------------------
# TESTING
# -----------------------------------------------
.pytest_cache/
.coverage
htmlcov/
test-results/

# -----------------------------------------------
# OS FILES
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------
# LOGS
# -----------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------
# AZURE
# -----------------------------------------------
.azure/
azure.json.local
