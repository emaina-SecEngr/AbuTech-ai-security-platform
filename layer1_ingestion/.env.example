# ==============================================
# ABUTECH AI SECURITY PLATFORM
# Environment Variables Template
# ==============================================
# Copy this file to .env and fill in real values
# NEVER commit the .env file to GitHub
# In production use Azure Key Vault or CyberArk
# ==============================================

# -----------------------------------------------
# SECRET PROVIDER CONFIGURATION
# Options: env_file, azure_key_vault, cyberark
# -----------------------------------------------
SECRET_PROVIDER=env_file

# -----------------------------------------------
# AI AND LLM SERVICES
# -----------------------------------------------
# Anthropic Claude API
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------
# SECURITY PLATFORM APIs
# -----------------------------------------------
# CrowdStrike Falcon API
# Get from: Falcon Console → API Clients
CROWDSTRIKE_CLIENT_ID=your_crowdstrike_client_id
CROWDSTRIKE_CLIENT_SECRET=your_crowdstrike_client_secret
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# Okta API
# Get from: Okta Admin Console → Security → API
OKTA_DOMAIN=your_okta_domain.okta.com
OKTA_API_TOKEN=your_okta_api_token

# Microsoft Sentinel / Entra ID
# Get from: Azure Portal → App Registrations
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id

# -----------------------------------------------
# THREAT INTELLIGENCE FEEDS
# -----------------------------------------------
# VirusTotal API - free tier available
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# AbuseIPDB API - free tier available
# Get from: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key

# Shodan API
# Get from: https://account.shodan.io
SHODAN_API_KEY=your_shodan_api_key

# -----------------------------------------------
# DATA STORAGE
# -----------------------------------------------
# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------
# DATABRICKS
# -----------------------------------------------
DATABRICKS_HOST=https://your_workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token
DATABRICKS_CLUSTER_ID=your_cluster_id

# -----------------------------------------------
# AZURE KEY VAULT (Staging/Production)
# -----------------------------------------------
AZURE_KEY_VAULT_URL=https://abutech-vault.vault.azure.net/

# -----------------------------------------------
# CYBERARK (Production Only)
# -----------------------------------------------
CYBERARK_AAM_URL=https://cyberark.company.com
CYBERARK_APP_ID=AbuTech-Platform
CYBERARK_SAFE=AbuTech-Production-Safe
CYBERARK_CERT_PATH=/etc/ssl/cyberark/cert.pem

# -----------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=15
PLATFORM_NAME=AbuTech AI Security Platform
PLATFORM_VERSION=1.0.0
